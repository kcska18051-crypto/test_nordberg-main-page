        var mapDealers;

        function initMap() {
            initDealersMap();
            initContactsMap();
        }

        function initDealersMap() {
            mapDealers = new google.maps.Map(document.getElementById('map'), {
                center: {lat: 58.2841761, lng: 56.4850113},
                zoom: 5,
                scrollWheel: 'none',
                gestureHandling: 'cooperative',
                zoomControl: true,
                mapTypeControl: false,
                scaleControl: false,
                streetViewControl: false,
                rotateControl: false,
                fullscreenControl: false,
                styles: mapStyles
            });

            // Map markets
            for (var i = 0; i < window.dealers.length; i++) {

                var marker = new google.maps.Marker({
                    position: {
                        lat: parseFloat(window.dealers[i].coordinates[0]),
                        lng: parseFloat(window.dealers[i].coordinates[1])
                    },
                    map: mapDealers,
                    icon: markerImage,
                    zIndex: markerZindex
                });

                google.maps.event.addListener(marker, 'click', (function (marker, markerCount) {
                    return function () {
                        var infowindow = new google.maps.InfoWindow();

                        var infoWindowData = '';
                        if (window.dealers[markerCount].name) {
                            infoWindowData += '<div style="color:#02aeef;font:600 18px Geometria, sans-serif;">' + window.dealers[markerCount].name + '</div>';
                            infoWindowData += '<div style="color:#222;font:600 16px Geometria, sans-serif;">' + window.dealers[markerCount].city + '</div>';
                        } else {
                            infoWindowData += '<div style="color:#02aeef;font:600 18px Geometria, sans-serif;">' + window.dealers[markerCount].city + '</div>';
                        }

                        if (window.dealers[markerCount].service == 2) {
                            infoWindowData += '<div style="color:#02aeef;font:400 14px Geometria, sans-serif;">Сервисный центр</div>';
                        }

                        if (window.dealers[markerCount].description) {
                            infoWindowData += '<div style="color:#222;font:400 14px Geometria, sans-serif;">' + window.dealers[markerCount].description + '</div>';
                        }

                        infowindow.setContent(infoWindowData);
                        infowindow.open(map, marker);
                    }
                })(marker, i));

            }

        }

        var mapContacts;

        function initContactsMap() {
            mapContacts = new google.maps.Map(document.getElementById('map_contacts'), {
                center: {lat: 54.634538, lng: 40.438807},
                zoom: 5,
                scrollWheel: 'none',
                gestureHandling: 'cooperative',
                zoomControl: true,
                mapTypeControl: false,
                scaleControl: false,
                streetViewControl: false,
                rotateControl: false,
                fullscreenControl: false,
                styles: mapStyles
            });

            var markerImage = '/bitrix/templates/nordberg/img/marker.png';

